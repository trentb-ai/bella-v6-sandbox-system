{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@bella/contracts": ["../contracts/src"],
      "@bella/telemetry": ["../telemetry/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
